# Bot backend selection: rule-based | openai | ollama
BOT_BACKEND=rule-based

# If enabled, failed OpenAI requests automatically fall back to Ollama, then rule-based.
ALLOW_BACKEND_FALLBACK=1

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

# Ollama settings (no API token required)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Prompt and logging settings
SYSTEM_PROMPT_PATH=src/prompts/system_prompt.txt